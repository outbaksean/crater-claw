{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-console",
            "type": "shell",
            "command": "dotnet build .\\CraterClaw.Console\\CraterClaw.Console.csproj",
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-api",
            "type": "shell",
            "command": "dotnet build .\\CraterClaw.Api\\CraterClaw.Api.csproj",
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run CraterClaw Console (with args)",
            "type": "shell",
            "command": "dotnet run --project .\\CraterClaw.Console -- ${input:consoleArgs}",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Run All Unit Tests",
            "type": "shell",
            "command": "dotnet test .\\CraterClaw.slnx",
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Verify Formatting (dotnet format)",
            "type": "shell",
            "command": "dotnet format .\\CraterClaw.slnx --verify-no-changes",
            "group": "test",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "consoleArgs",
            "type": "promptString",
            "description": "Arguments to pass to CraterClaw.Console (example: .\\provider-config.json)",
            "default": ".\\provider-config.json"
        }
    ]
}